{
  "name": "promptrace",
  "version": "0.1.1",
  "description": "Git-style version control for LLM prompts",
  "main": "index.js",
  "bin": {
    "promptrace": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs",
    "dev": "tsx src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["prompt", "llm", "version-control", "ai", "cli", "diff"],
  "author": "Orbital Labs",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-orbital-labs/promptrace"
  },
  "homepage": "https://github.com/the-orbital-labs/promptrace#readme",
  "bugs": {
    "url": "https://github.com/the-orbital-labs/promptrace/issues"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chalk": "^4.1.2",
    "commander": "^15.0.0",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}